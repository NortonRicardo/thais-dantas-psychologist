# Banco de dados PostgreSQL (dev — docker-compose-dev.yml)
POSTGRES_USER=lemm
POSTGRES_PASSWORD=lemm
POSTGRES_DB=lemm
DATABASE_URL=postgres://lemm:lemm@localhost:5432/lemm

# Segredo do Better Auth — gere com: openssl rand -hex 32
BETTER_AUTH_SECRET=dev-secret-32-chars-change-in-prod

# URL pública da aplicação (sem barra final)
BETTER_AUTH_URL=http://localhost:3000

# URL interna para fetches server-side do Better Auth.
# Em produção (Docker): http://localhost:3020  (porta interna, sem TLS)
# Se ausente, usa BETTER_AUTH_URL — correto para dev, mas quebra em prod
# quando o TLS termina no reverse proxy e o container só fala HTTP.
# BETTER_AUTH_BASE_URL=http://localhost:3020

# Credenciais do admin — criadas automaticamente no seed (bun db:seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123123

# ─── Produção (Coolify / docker-compose.yml) ─────────────────────────────────
# POSTGRES_USER=seu_usuario_db
# POSTGRES_PASSWORD=senha_forte_db
# POSTGRES_DB=lemm
# DATABASE_URL=postgres://seu_usuario_db:senha_forte_db@db:5432/lemm
# BETTER_AUTH_SECRET=<openssl rand -hex 32>
# BETTER_AUTH_URL=https://seu-dominio.com
# BETTER_AUTH_BASE_URL=http://localhost:3020
# ADMIN_USERNAME=seu_usuario
# ADMIN_PASSWORD=sua_senha_forte
